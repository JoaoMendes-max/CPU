      <obj_property name="ObjectShortName">IF  valid</obj_property>
      <obj_property name="CustomSignalColor">#00DDDD</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/if_pc">
      <obj_property name="ElementShortName">IF  PC</obj_property>
      <obj_property name="ObjectShortName">IF  PC</obj_property>
      <obj_property name="RadixType">HEX</obj_property>
      <obj_property name="CustomSignalColor">#00DDDD</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/if_insn">
      <obj_property name="ElementShortName">IF  insn</obj_property>
      <obj_property name="ObjectShortName">IF  insn</obj_property>
      <obj_property name="RadixType">HEX</obj_property>
      <obj_property name="CustomSignalColor">#00DDDD</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>

   <!-- ======================= ID ========================== -->
   <wvobject type="divider" fp_name="div_id">
      <obj_property name="label">━━ ID ━━━━━━━━━━━━━━━━━━━━━━━━━━━━</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/id_v">
      <obj_property name="ElementShortName">ID  valid</obj_property>
      <obj_property name="ObjectShortName">ID  valid</obj_property>
      <obj_property name="CustomSignalColor">#DDDD00</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/id_pc">
      <obj_property name="ElementShortName">ID  PC</obj_property>
      <obj_property name="ObjectShortName">ID  PC</obj_property>
      <obj_property name="RadixType">HEX</obj_property>
      <obj_property name="CustomSignalColor">#DDDD00</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/dut/u_cpu/u_id_stage/i_insn">
      <obj_property name="ElementShortName">ID  insn</obj_property>
      <obj_property name="ObjectShortName">ID  insn</obj_property>
      <obj_property name="RadixType">HEX</obj_property>
      <obj_property name="CustomSignalColor">#DDDD00</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/dut/u_cpu/_id_rd">
      <obj_property name="ElementShortName">ID  rd</obj_property>
      <obj_property name="ObjectShortName">ID  rd</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/dut/u_cpu/_id_rs">
      <obj_property name="ElementShortName">ID  rs</obj_property>
      <obj_property name="ObjectShortName">ID  rs</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
   </wvobject>

   <!-- ======================= EX ========================== -->
   <wvobject type="divider" fp_name="div_ex">
      <obj_property name="label">━━ EX ━━━━━━━━━━━━━━━━━━━━━━━━━━━━</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/ex_v">
      <obj_property name="ElementShortName">EX  valid</obj_property>
      <obj_property name="ObjectShortName">EX  valid</obj_property>
      <obj_property name="CustomSignalColor">#AAAAAA</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/ex_pc">
      <obj_property name="ElementShortName">EX  PC</obj_property>
      <obj_property name="ObjectShortName">EX  PC</obj_property>
      <obj_property name="RadixType">HEX</obj_property>
      <obj_property name="CustomSignalColor">#AAAAAA</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/dut/u_cpu/_idex_rd">
      <obj_property name="ElementShortName">EX  rd</obj_property>
      <obj_property name="ObjectShortName">EX  rd</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/dut/u_cpu/_idex_rs">
      <obj_property name="ElementShortName">EX  rs</obj_property>
      <obj_property name="ObjectShortName">EX  rs</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
   </wvobject>
   <!-- Operandos antes do forward mux — valor "stale" do regfile -->
   <wvobject type="array" fp_name="/tb_forwarding_01/dut/u_cpu/_idex_rd_data">
      <obj_property name="ElementShortName">EX  rd_data [regfile]</obj_property>
      <obj_property name="ObjectShortName">EX  rd_data [regfile]</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/dut/u_cpu/_idex_rs_data">
      <obj_property name="ElementShortName">EX  rs_data [regfile]</obj_property>
      <obj_property name="ObjectShortName">EX  rs_data [regfile]</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
   </wvobject>
   <!-- ALU result — valor que sai do EX -->
   <wvobject type="array" fp_name="/tb_forwarding_01/dut/u_cpu/u_ex_stage/o_wb_pre_data">
      <obj_property name="ElementShortName">EX  ALU result</obj_property>
      <obj_property name="ObjectShortName">EX  ALU result</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
      <obj_property name="CustomSignalColor">#AAAAAA</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>

   <!-- ======================= FORWARDING ================== -->
   <!-- Este é o grupo mais importante para debugging do forwarding -->
   <wvobject type="divider" fp_name="div_fwd">
      <obj_property name="label">━━ FORWARDING ★ ━━━━━━━━━━━━━━━━━━</obj_property>
   </wvobject>
   <!-- ForwardAE e ForwardBE: quando = 1 há forwarding activo -->
   <wvobject type="logic" fp_name="/tb_forwarding_01/fwd_a">
      <obj_property name="ElementShortName">★ ForwardAE  (rd usa MEM)</obj_property>
      <obj_property name="ObjectShortName">★ ForwardAE  (rd usa MEM)</obj_property>
      <obj_property name="CustomSignalColor">#FF5500</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/fwd_b">
      <obj_property name="ElementShortName">★ ForwardBE  (rs usa MEM)</obj_property>
      <obj_property name="ObjectShortName">★ ForwardBE  (rs usa MEM)</obj_property>
      <obj_property name="CustomSignalColor">#FF5500</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <!-- O dado que é efectivamente forwarded para o EX -->
   <wvobject type="array" fp_name="/tb_forwarding_01/fwd_dat">
      <obj_property name="ElementShortName">★ FWD_DATA   (exmem_wb)</obj_property>
      <obj_property name="ObjectShortName">★ FWD_DATA   (exmem_wb)</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
      <obj_property name="CustomSignalColor">#FF5500</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <!-- Registos comparados pelo forwarding unit -->
   <wvobject type="array" fp_name="/tb_forwarding_01/frd_ex">
      <obj_property name="ElementShortName">  rdE   (reg em EX lê)</obj_property>
      <obj_property name="ObjectShortName">  rdE   (reg em EX lê)</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/frs_ex">
      <obj_property name="ElementShortName">  rsE   (reg em EX lê)</obj_property>
      <obj_property name="ObjectShortName">  rsE   (reg em EX lê)</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/frd_mem">
      <obj_property name="ElementShortName">  WriteRegM (reg em MEM escreve)</obj_property>
      <obj_property name="ObjectShortName">  WriteRegM (reg em MEM escreve)</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
   </wvobject>

   <!-- ======================= MEM ========================= -->
   <wvobject type="divider" fp_name="div_mem">
      <obj_property name="label">━━ MEM ━━━━━━━━━━━━━━━━━━━━━━━━━━━</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/mem_v">
      <obj_property name="ElementShortName">MEM valid</obj_property>
      <obj_property name="ObjectShortName">MEM valid</obj_property>
      <obj_property name="CustomSignalColor">#CC6600</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/mem_pc">
      <obj_property name="ElementShortName">MEM PC</obj_property>
      <obj_property name="ObjectShortName">MEM PC</obj_property>
      <obj_property name="RadixType">HEX</obj_property>
      <obj_property name="CustomSignalColor">#CC6600</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/dut/u_cpu/_exmem_rd">
      <obj_property name="ElementShortName">MEM rd  (dest que vai escrever)</obj_property>
      <obj_property name="ObjectShortName">MEM rd  (dest que vai escrever)</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/dut/u_cpu/_exmem_rf_we">
      <obj_property name="ElementShortName">MEM rf_we</obj_property>
      <obj_property name="ObjectShortName">MEM rf_we</obj_property>
   </wvobject>

   <!-- ======================= WB ========================== -->
   <wvobject type="divider" fp_name="div_wb">
      <obj_property name="label">━━ WB ━━━━━━━━━━━━━━━━━━━━━━━━━━━━</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/wb_v">
      <obj_property name="ElementShortName">WB  valid</obj_property>
      <obj_property name="ObjectShortName">WB  valid</obj_property>
      <obj_property name="CustomSignalColor">#BB44BB</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <!-- rf_we + rf_wa + rf_wd: o trio mais útil para confirmar resultados -->
   <wvobject type="logic" fp_name="/tb_forwarding_01/rf_we">
      <obj_property name="ElementShortName">WB  rf_we</obj_property>
      <obj_property name="ObjectShortName">WB  rf_we</obj_property>
      <obj_property name="CustomSignalColor">#BB44BB</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/rf_wa">
      <obj_property name="ElementShortName">WB  rf_wa  (dest)</obj_property>
      <obj_property name="ObjectShortName">WB  rf_wa  (dest)</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
      <obj_property name="CustomSignalColor">#BB44BB</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="array" fp_name="/tb_forwarding_01/rf_wd">
      <obj_property name="ElementShortName">WB  rf_wd  (valor)</obj_property>
      <obj_property name="ObjectShortName">WB  rf_wd  (valor)</obj_property>
      <obj_property name="RadixType">UNSIGNED</obj_property>
      <obj_property name="CustomSignalColor">#BB44BB</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>

   <!-- ======================= HAZARD ====================== -->
   <wvobject type="divider" fp_name="div_haz">
      <obj_property name="label">━━ HAZARD ━━━━━━━━━━━━━━━━━━━━━━━━</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/stall_if">
      <obj_property name="ElementShortName">stall_if</obj_property>
      <obj_property name="ObjectShortName">stall_if</obj_property>
