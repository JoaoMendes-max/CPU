<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_forwarding_01_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_forwarding_01" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="100 ns"></ZoomStartTime>
      <ZoomEndTime time="460 ns"></ZoomEndTime>
      <Cursor1Time time="115 ns"></Cursor1Time>
      <Cursor2Time time="175 ns"></Cursor2Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="240"></NameColumnWidth>
      <ValueColumnWidth column_width="80"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="60" />

   <!-- ======================= CLOCK ======================= -->
   <wvobject type="divider" fp_name="div_clk">
      <obj_property name="label">CLOCK / RESET</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/_clk">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/_rst">
      <obj_property name="ElementShortName">rst</obj_property>
      <obj_property name="ObjectShortName">rst</obj_property>
   </wvobject>

   <!-- ======================= IF ========================== -->
   <wvobject type="divider" fp_name="div_if">
      <obj_property name="label">━━ IF ━━━━━━━━━━━━━━━━━━━━━━━━━━━━</obj_property>
   </wvobject>
