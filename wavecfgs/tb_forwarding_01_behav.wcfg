      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/stall_id">
      <obj_property name="ElementShortName">stall_id</obj_property>
      <obj_property name="ObjectShortName">stall_id</obj_property>
      <obj_property name="CustomSignalColor">#FF0000</obj_property>
