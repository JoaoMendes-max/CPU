   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/luh">
      <obj_property name="ElementShortName">load_use_hazard</obj_property>
      <obj_property name="ObjectShortName">load_use_hazard</obj_property>
      <obj_property name="CustomSignalColor">#FF0000</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/flush_if">
      <obj_property name="ElementShortName">flush_ifid</obj_property>
      <obj_property name="ObjectShortName">flush_ifid</obj_property>
      <obj_property name="CustomSignalColor">#FF8800</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>

   <!-- ======================= CONDITION CODES ============= -->
   <wvobject type="divider" fp_name="div_cc">
      <obj_property name="label">━━ CC  (TEST 5) ━━━━━━━━━━━━━━━━━━</obj_property>
   </wvobject>
   <!-- ex_flag_we=1 é o momento exacto em que o CC é válido -->
   <wvobject type="logic" fp_name="/tb_forwarding_01/ex_flag_we">
      <obj_property name="ElementShortName">EX  flag_we  (CC update)</obj_property>
      <obj_property name="ObjectShortName">EX  flag_we  (CC update)</obj_property>
      <obj_property name="CustomSignalColor">#00CC44</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <!-- Ler ex_new_ccz no ciclo em que ex_flag_we=1 — valor correcto -->
   <wvobject type="logic" fp_name="/tb_forwarding_01/ex_ccz">
      <obj_property name="ElementShortName">EX  new_ccz  (Z gerado)</obj_property>
      <obj_property name="ObjectShortName">EX  new_ccz  (Z gerado)</obj_property>
      <obj_property name="CustomSignalColor">#00CC44</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/ex_ccn">
      <obj_property name="ElementShortName">EX  new_ccn  (N gerado)</obj_property>
      <obj_property name="ObjectShortName">EX  new_ccn  (N gerado)</obj_property>
      <obj_property name="CustomSignalColor">#00CC44</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <!-- _ccz arquitectural — vês aqui o bug: reseta a 0 no ciclo seguinte -->
   <wvobject type="logic" fp_name="/tb_forwarding_01/dut/u_cpu/_ccz">
      <obj_property name="ElementShortName">CPU _ccz  (BUG: reseta a 0)</obj_property>
      <obj_property name="ObjectShortName">CPU _ccz  (BUG: reseta a 0)</obj_property>
      <obj_property name="CustomSignalColor">#FF0000</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="logic" fp_name="/tb_forwarding_01/dut/u_cpu/_ccn">
      <obj_property name="ElementShortName">CPU _ccn</obj_property>
      <obj_property name="ObjectShortName">CPU _ccn</obj_property>
   </wvobject>

   <!-- ======================= REGFILE MIRRORS ============= -->
   <wvobject type="divider" fp_name="div_rf">
