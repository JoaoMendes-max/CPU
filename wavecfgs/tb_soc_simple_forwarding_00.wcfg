   <!-- REGISTER FILE  (debug mirrors)                                     -->
   <!-- Valores esperados:                                                  -->
   <!--   t0=1, t1=2, t2=3, t3=4  (TEST 1)                                -->
   <!--   t1=11                    (TEST 2)                                 -->
   <!--   t0=16                    (TEST 3: 1→2→4→8→16)                   -->
   <!--   t2=8, t3=5               (TEST 4)                                 -->
   <!--   t2=5, Z=1                (TEST 5)                                 -->
